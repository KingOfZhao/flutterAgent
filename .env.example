# Copy this to .env and fill in your values

# ---------------------------------------------------------------------------
# DeepSeek (or any OpenAI-compatible) endpoint
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model name passed verbatim to the upstream provider's `model` field.
# "deepseek-v4-pro" is used here as a placeholder. If your DeepSeek account
# does not have it, fall back to one of the published models:
#   * deepseek-chat       (V3 series, general chat)
#   * deepseek-reasoner   (R1 series, reasoning)
# See https://api-docs.deepseek.com/quick_start/pricing for current options
# and prices. The pipeline is OpenAI-compatible so any provider works:
#   * OpenAI:   DEEPSEEK_BASE_URL=https://api.openai.com/v1   DEEPSEEK_MODEL=gpt-4o
#   * Together: DEEPSEEK_BASE_URL=https://api.together.xyz/v1
#   * Local Ollama: DEEPSEEK_BASE_URL=http://127.0.0.1:11434/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Reasoning / planning model (optional, defaults to DEEPSEEK_MODEL)
DEEPSEEK_PLANNER_MODEL=deepseek-reasoner

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=127.0.0.1
PORT=8765

# Local API gate-key (clients must pass this as Bearer token).
# Leave empty to disable auth.
LOCAL_API_KEY=

# Skills directory (relative to repo root or absolute)
SKILLS_DIR=skills

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# "text" (human-readable, default) or "json" (structured, for log aggregators)
LOG_FORMAT=text
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Generation defaults
# ---------------------------------------------------------------------------
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_TOKENS=4096
REQUEST_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Pricing (optional)
# ---------------------------------------------------------------------------
# Override the built-in MODEL_PRICING table with a JSON file.
# See `src/flutter_agent/pricing.py` for the schema. Example file content:
#   {"deepseek-v4-pro": {"input_per_million": 0.27, "output_per_million": 1.10}}
# PRICING_CONFIG=/path/to/pricing.json
